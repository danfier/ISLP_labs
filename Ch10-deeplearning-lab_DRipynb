        "                       max_epochs=20,\n",
        "                       logger=lstm_logger,\n",
        "                       enable_progress_bar=False,\n",
        "                       callbacks=[ErrorTracker()])\n",
        "lstm_trainer.fit(lstm_module,\n",
        "                 datamodule=imdb_seq_dm)\n"
      ]
